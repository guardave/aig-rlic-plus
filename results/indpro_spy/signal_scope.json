  "indicator_axis": {
    "canonical_column": "indpro",
    "display_name": "Industrial Production Index (INDPRO)",
    "derivatives": [
      {
        "name": "indpro",
        "definition": "Raw INDPRO level index (Federal Reserve, base 2017=100).",
        "formula": "raw column, unit = index",
        "role": "raw",
        "appears_in_charts": [
          "hero",
          "history_zoom_gfc",
          "history_zoom_covid",
          "correlation_heatmap"
        ],
        "notes": ""
      },
      {
        "name": "indpro_yoy",
        "definition": "Year-over-year percent change in INDPRO.",
        "formula": "(indpro[t] / indpro[t-12] - 1) * 100",
        "role": "derivative",
        "appears_in_charts": [
          "correlation_heatmap"
        ],
        "notes": "S2_yoy in tournament."
      },
      {
        "name": "indpro_mom",
        "definition": "Month-over-month percent change in INDPRO.",
        "formula": "(indpro[t] / indpro[t-1] - 1) * 100",
        "role": "derivative",
        "appears_in_charts": [
          "correlation_heatmap"
        ],
        "notes": "S3_mom in tournament."
      },
      {
        "name": "indpro_dev_trend",
        "definition": "Deviation from Hodrick-Prescott trend.",
        "formula": "indpro[t] - hp_trend[t]",
        "role": "derivative",
        "appears_in_charts": [
          "correlation_heatmap"
        ],
        "notes": "S4_dev_trend in tournament."
      },
      {
        "name": "indpro_zscore_60m",
        "definition": "60-month rolling z-score of INDPRO.",
        "formula": "(indpro[t] - rolling_mean_60(indpro)) / rolling_std_60(indpro)",
        "role": "threshold_input",
        "appears_in_charts": [
          "correlation_heatmap"
        ],
        "notes": "S5_zscore in tournament. Key finding signal."
      },
      {
        "name": "indpro_mom3m",
        "definition": "3-month momentum: cumulative return over last 3 months.",
        "formula": "indpro[t] / indpro[t-3] - 1",
        "role": "derivative",
        "appears_in_charts": [
          "hero",
          "correlation_heatmap"
        ],
        "notes": "S6_mom3m \u2014 tournament WINNER. Threshold: T1_fixed_p75."
      },
      {
        "name": "indpro_mom6m",
        "definition": "6-month momentum: cumulative return over last 6 months.",
        "formula": "indpro[t] / indpro[t-6] - 1",
        "role": "derivative",
        "appears_in_charts": [
          "correlation_heatmap"
        ],
        "notes": "S7_mom6m in tournament."
      },
      {
        "name": "indpro_accel",
        "definition": "Acceleration: 2nd derivative (mom-of-mom).",
        "formula": "indpro_mom3m[t] - indpro_mom3m[t-3]",
        "role": "derivative",
        "appears_in_charts": [
          "correlation_heatmap"
        ],
        "notes": "S8_accel in tournament."
      },
      {
        "name": "indpro_contraction",
        "definition": "Binary: 1 when INDPRO is below its 12m rolling min.",
        "formula": "1 if indpro[t] < rolling_min_12(indpro) else 0",
        "role": "regime_state",
        "appears_in_charts": [
          "regime_returns"
        ],
        "notes": "S9_contraction in tournament."
